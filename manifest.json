{
  "manifest_version": 3,
  "name": "Better MyEd",
  "version": "1.4",
  "description": "Improves the layout and usability of the BC MyEducation portal.",
  "permissions": ["storage", "scripting", "activeTab"],
  "optional_host_permissions": [
    "https://*.myeducation.gov.bc.ca/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Better MyEd",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
